{
  "expo": {
    "name": "barbershop",
    "slug": "barbershop",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-dark.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon-dark.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-dark.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.elrobertds.barbershop"
    },
    "web": {
      "favicon": "./assets/icon-dark.png"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon-dark.png",
          "color": "#C0A060"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "034715c3-bb2e-48e4-b540-6eb0bd57079b"
      }
    }
  }
}
